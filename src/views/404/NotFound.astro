---

<div class="min-h-svh flex justify-center items-center flex-col text-center px-6">

  <!-- Big 404 -->
  <p
    class="codec-pro mb-6 text-[10rem] font-medium leading-none text-[#2d5d54]/10 select-none
    max-[600px]:text-[7rem] max-[400px]:text-[5rem]
    animate__animated animate__zoomIn animate__fast"
  >
    404
  </p>

  <!-- Eyebrow -->
  <p
    class="text-xs font-semibold tracking-widest text-[#2d5d54] uppercase mb-3 -mt-6
    animate__animated animate__fadeInUp animate__fast"
  >
    — PÁGINA NO ENCONTRADA
  </p>

  <!-- Heading -->
  <h1
    class="codec-pro text-4xl font-medium mb-4
    max-[600px]:text-3xl max-[400px]:text-2xl
    animate__animated animate__fadeInUp animate__fast"
  >
    Te perdiste en el mapa
  </h1>

  <!-- Subtext -->
  <p
    class="text-gray-500 text-lg max-w-sm leading-relaxed mb-10
    max-[600px]:text-base
    animate__animated animate__fadeInUp animate__fast"
  >
    Esta página no existe… ni siquiera un bug la habita.
  </p>

  <!-- CTA -->
  <a
    href="/"
    class="cta-primary rounded-xl bg-[#2d5d54] hover:bg-[#2c7c6e] transition-all text-white px-7 py-3 flex gap-2 items-center
    animate__animated animate__fadeInUp animate__fast"
  >
    <span class="text-base">Volver al inicio</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
      <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"/>
    </svg>
  </a>

</div>

<style>
  .cta-primary:hover {
    transform: scale(1.04);
  }
</style>
