---
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  image: any;
  link: string;
}

const { title, description, image, link } = Astro.props;

const cleanTitle = title
  .replaceAll(" ", "-")
  .replaceAll(".", "-")
  .toLowerCase();
const id = "card-" + cleanTitle;
---

<div
  id={id}
  class="card-project overflow-clip w-[820px] flex flex-row bg-white rounded-2xl animate__fast animate-on-view animation-forwards animate__animated
  max-[850px]:flex-col
  max-[850px]:w-[620px]
  max-[660px]:w-[calc(100%-60px)]"
  data-aov-animation="animate__zoomIn"
>
  <div class="img-wrapper shrink-0 w-[45%] max-[850px]:w-full max-[850px]:h-[220px] overflow-hidden">
    <Image
      src={image}
      alt={`Imagen del proyecto: ${title}`}
      class="card-img w-full h-full object-cover"
      inferSize
    />
  </div>
  <div
    class="px-6 py-8 flex flex-col justify-center w-full max-[660px]:px-4 max-[660px]:py-6"
  >
    <h2 class="text-2xl font-medium m-0 text-start max-[660px]:text-xl">
      {title}
    </h2>
    <p class="text-lg mt-2 text-gray-600 max-[660px]:text-base max-[550px]:text-sm">
      {description}
    </p>
    <a
      href={`/projects/${cleanTitle}`}
      target="_self"
      class="mt-8 w-fit text-base max-[850px]:text-lg max-[660px]:mt-4 max-[550px]:text-base font-normal rounded-xl bg-[#2d5d54] hover:bg-[#3e8b7d] transition-colors text-white px-6 py-2"
    >
      Ver proyecto
    </a>
  </div>
</div>

<style>
  .card-project {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .card-project:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
  }

  .card-img {
    transition: filter 0.4s ease, transform 0.4s ease;
    filter: grayscale(25%) contrast(95%);
  }

  .card-project:hover .card-img {
    filter: grayscale(0%) contrast(100%);
    transform: scale(1.03);
  }
</style>
