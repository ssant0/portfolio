---
import { socialLinks } from "../../../data/socialLinks";
---

<div
  id="intro"
  class="flex flex-col items-center justify-center mt-44 animate__animated animate__zoomIn animate__delay-3s animate__fast
  w-[860px] max-[1080px]:w-[700px]
  max-[800px]:w-[580px]
  max-[800px]:mt-40
  max-[660px]:w-[500px]
  max-[660px]:mt-28
  max-[550px]:w-[400px]
  max-[440px]:w-[350px]
  max-[382px]:w-[300px]"
>
  <!-- Avatar -->
  <div class="avatar-ring w-24 h-24 rounded-full bg-[#2d5d54] flex items-center justify-center mb-6 ring-4 ring-[#2d5d54]/20 max-[660px]:w-20 max-[660px]:h-20 max-[382px]:w-16 max-[382px]:h-16">
    <span class="text-white text-3xl font-semibold codec-pro tracking-tight max-[382px]:text-2xl">MS</span>
  </div>

  <!-- Badge -->
  <div class="flex items-center gap-2 px-4 py-1.5 bg-[#2d5d54]/10 rounded-full mb-3">
    <span class="text-[#2d5d54] text-sm font-medium tracking-wide">&lt;/&gt;&nbsp;&nbsp;Desarrollador Web</span>
  </div>

  <h1
    class="pt-1 text-6xl codec-pro font-medium max-[800px]:text-5xl max-[660px]:text-4xl max-[382px]:text-3xl"
  >
    Manuel Samaniego
  </h1>
  <p
    class="text-lg text-center pt-3 max-w-[540px] text-gray-600 max-[660px]:text-base max-[660px]:mt-1 max-[550px]:text-sm max-[382px]:text-xs"
  >
    Creo soluciones web a medida para pymes y emprendedores, con diseño
    personalizado, implementación eficiente y acompañamiento desde
    el primer clic.
  </p>

  <!-- Social links -->
  <div
    class="flex pt-5 max-[660px]:pt-4 items-center gap-2 animate__animated animate__zoomIn animate__delay-4s animate__fast media-links"
  >
    <a
      href={socialLinks.instagram}
      target="_blank"
      aria-label="Instagram"
      class="transition-all duration-300 w-[44px] h-[44px] max-[800px]:w-[38px] max-[800px]:h-[38px] flex items-center justify-center border-solid rounded-xl border-[#2d5d54] border-2 p-2 hover:bg-[#2d5d54] hover:fill-white max-[382px]:w-[34px] max-[382px]:h-[34px]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" class="transition-all duration-300 bi bi-instagram" viewBox="0 0 16 16">
        <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"></path>
      </svg>
    </a>

    <a
      href={`mailto:${socialLinks.email}`}
      target="_blank"
      aria-label="Email"
      class="transition-all duration-300 w-[44px] h-[44px] max-[800px]:w-[38px] max-[800px]:h-[38px] flex items-center justify-center border-solid rounded-xl border-[#2d5d54] border-2 p-2 hover:bg-[#2d5d54] hover:fill-white max-[382px]:w-[34px] max-[382px]:h-[34px]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" id="Outline" viewBox="0 0 24 24" width="100%" height="100%">
        <path d="M19,1H5A5.006,5.006,0,0,0,0,6V18a5.006,5.006,0,0,0,5,5H19a5.006,5.006,0,0,0,5-5V6A5.006,5.006,0,0,0,19,1ZM5,3H19a3,3,0,0,1,2.78,1.887l-7.658,7.659a3.007,3.007,0,0,1-4.244,0L2.22,4.887A3,3,0,0,1,5,3ZM19,21H5a3,3,0,0,1-3-3V7.5L8.464,13.96a5.007,5.007,0,0,0,7.072,0L22,7.5V18A3,3,0,0,1,19,21Z"></path>
      </svg>
    </a>

    <a
      href={socialLinks.linkedin}
      target="_blank"
      aria-label="LinkedIn"
      class="transition-all duration-300 w-[44px] h-[44px] max-[800px]:w-[38px] max-[800px]:h-[38px] flex items-center justify-center border-solid rounded-xl border-[#2d5d54] border-2 p-2 hover:bg-[#2d5d54] hover:fill-white max-[382px]:w-[34px] max-[382px]:h-[34px]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" class="transition-all duration-300 bi bi-linkedin" viewBox="0 0 16 16">
        <path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"></path>
      </svg>
    </a>

    <a
      href={socialLinks.github}
      target="_blank"
      aria-label="GitHub"
      class="transition-all duration-300 w-[44px] h-[44px] max-[800px]:w-[38px] max-[800px]:h-[38px] flex items-center justify-center border-solid rounded-xl border-[#2d5d54] border-2 p-2 hover:bg-[#2d5d54] hover:fill-white max-[382px]:w-[34px] max-[382px]:h-[34px]"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" class="transition-all duration-300 bi bi-github" viewBox="0 0 16 16">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"></path>
      </svg>
    </a>
  </div>

  <!-- CTAs -->
  <div
    class="flex gap-3 pt-8 animate__animated animate__fadeInUp animate__delay-5s animate__fast max-[550px]:flex-col max-[550px]:items-center"
  >
    <a
      href={`mailto:${socialLinks.email}`}
      class="cta-primary rounded-xl bg-[#2d5d54] hover:bg-[#2c7c6e] transition-all text-white px-7 py-3 flex gap-2 items-center max-[660px]:px-5"
    >
      <span class="text-lg max-[660px]:text-base max-[382px]:text-sm">Hablemos de tu proyecto</span>
      <div class="w-5 h-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" class="bi bi-chat-text" viewBox="0 0 16 16">
          <path d="M2.678 11.894a1 1 0 0 1 .287.801 11 11 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8 8 0 0 0 8 14c3.996 0 7-2.807 7-6s-3.004-6-7-6-7 2.808-7 6c0 1.468.617 2.83 1.678 3.894m-.493 3.905a22 22 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a10 10 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9 9 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105"></path>
          <path d="M4 5.5a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7a.5.5 0 0 1-.5-.5M4 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 4 8m0 2.5a.5.5 0 0 1 .5-.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 1-.5-.5"></path>
        </svg>
      </div>
    </a>
    <button
      id="btn-ver-proyectos"
      class="cta-secondary rounded-xl border-2 border-[#2d5d54] text-[#2d5d54] hover:bg-[#2d5d54] hover:text-white transition-all px-7 py-3 flex gap-2 items-center max-[660px]:px-5 cursor-pointer"
    >
      <span class="text-lg max-[660px]:text-base max-[382px]:text-sm">Ver proyectos</span>
      <div class="w-5 h-5">
        <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" fill="currentColor" viewBox="0 0 16 16">
          <path fill-rule="evenodd" d="M8 1a.5.5 0 0 1 .5.5v11.793l3.146-3.147a.5.5 0 0 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-4-4a.5.5 0 0 1 .708-.708L7.5 13.293V1.5A.5.5 0 0 1 8 1"/>
        </svg>
      </div>
    </button>
  </div>
</div>

<style>
  .media-links a:hover svg {
    fill: white;
  }

  .cta-primary:hover {
    transform: scale(1.04);
  }

  .cta-secondary:hover {
    transform: scale(1.04);
  }

  .avatar-ring {
    box-shadow: 0 0 0 6px rgba(45, 93, 84, 0.12), 0 4px 20px rgba(45, 93, 84, 0.2);
  }
</style>

<script>
  document.getElementById('btn-ver-proyectos')?.addEventListener('click', () => {
    document.getElementById('recent-projects')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
