---
import ProjectCard from "../components/ProjectCard.astro";
import { allProjects } from "../../../data/allProjects";
---

<div
  id="recent-projects"
  class="flex flex-col items-center justify-center mt-72 max-[660px]:mt-30"
>
  <p class="text-xs font-semibold tracking-widest text-[#2d5d54] uppercase mb-2 animate__animated animate__fast animate-on-view" data-aov-animation="animate__fadeInUp">— PORTAFOLIO</p>
  <h2
    class="pt-1 text-6xl text-center rubik max-[800px]:text-5xl max-[660px]:text-4xl max-[382px]:text-3xl animate__animated animate__fast animate-on-view max-[460px]:px-4"
    data-aov-animation="animate__zoomIn"
  >
    Proyectos
  </h2>

  <div class="pt-8 flex items-center justify-center w-full">
    <div
      class="w-[1180px] flex items-center justify-center flex-wrap gap-8
    max-[1225px]:w-[780px] max-[820px]:w-[580px] max-[820px]:justify-center max-[660px]:w-full"
    >
      {
        allProjects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.shortDescription}
            image={project.image}
            link={project.liveLink}
            technologies={project.technologies}
          />
        ))
      }
    </div>
  </div>
</div>

